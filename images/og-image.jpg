<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 500 500" width="500" height="500">
  <!-- Outer crosshair ring -->
  <circle cx="250" cy="150" r="75" fill="none" stroke="#FFFFFF" stroke-width="5"/>
  <circle cx="250" cy="150" r="63" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="1.5"/>

  <!-- Crosshair ticks (4 directions) -->
  <line x1="250" y1="65" x2="250" y2="85" stroke="#FFFFFF" stroke-width="3.5" stroke-linecap="round"/>
  <line x1="250" y1="215" x2="250" y2="235" stroke="#FFFFFF" stroke-width="3.5" stroke-linecap="round"/>
  <line x1="165" y1="150" x2="185" y2="150" stroke="#FFFFFF" stroke-width="3.5" stroke-linecap="round"/>
  <line x1="315" y1="150" x2="335" y2="150" stroke="#FFFFFF" stroke-width="3.5" stroke-linecap="round"/>

  <!-- Inner solid blue circle -->
  <circle cx="250" cy="150" r="38" fill="#4A90D9"/>

  <!-- White check mark -->
  <polyline points="232,150 245,166 270,134" fill="none" stroke="#FFFFFF" stroke-width="5.5" stroke-linecap="round" stroke-linejoin="round"/>

  <!-- Company name -->
  <text x="250" y="310" text-anchor="middle" font-family="'Inter', 'Segoe UI', Arial, Helvetica, sans-serif" font-weight="800" font-size="54" letter-spacing="10" fill="#FFFFFF">AETERNA</text>

  <!-- Left divider line -->
  <line x1="50" y1="363" x2="90" y2="363" stroke="#C8A96E" stroke-width="1.5"/>

  <!-- Subtext -->
  <text x="250" y="368" text-anchor="middle" font-family="'Inter', 'Segoe UI', Arial, Helvetica, sans-serif" font-weight="600" font-size="11" letter-spacing="3.5" fill="#C8A96E">INSPECTION &amp; TECHNICAL SERVICES</text>

  <!-- Right divider line -->
  <line x1="410" y1="363" x2="450" y2="363" stroke="#C8A96E" stroke-width="1.5"/>
</svg>
